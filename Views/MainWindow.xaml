<Window x:Class="StudentSIS.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ລະບົບຄຸ້ມຄອງຂໍ້ມູນນັກຮຽນ"
        Icon="/Assets/app-icon.ico"
        Width="1340" Height="820" MinWidth="1050" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        FontFamily="{DynamicResource AppFont}"
        Background="{StaticResource BgPageBrush}">
  <Grid>
    <Grid.ColumnDefinitions><ColumnDefinition Width="232"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

    <!-- ============================================================
         SIDEBAR  (flat solid color)
         ============================================================ -->
    <Border Grid.Column="0" Background="{StaticResource SidebarBrush}"
            BorderBrush="{StaticResource SidebarBorderBrush}" BorderThickness="0,0,1,0">
      <DockPanel>
        <!-- Brand block -->
        <Border DockPanel.Dock="Top" Height="80" Padding="14,0">
          <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Border Width="42" Height="42" CornerRadius="4"
                    Background="{StaticResource PrimaryBrush}"
                    VerticalAlignment="Center" SnapsToDevicePixels="True">
              <TextBlock Text="🎓" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
              <TextBlock x:Name="TxtSchool" Text="ໂຮງຮຽນ" Foreground="White" FontSize="13"
                         FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
          </Grid>
        </Border>
        <Rectangle DockPanel.Dock="Top" Height="1"
                   Fill="{StaticResource SidebarBorderBrush}"
                   Margin="14,0,14,6" SnapsToDevicePixels="True"/>

        <!-- Footer (user + logout) -->
        <Border DockPanel.Dock="Bottom" Height="64" Padding="12,0"
                BorderBrush="{StaticResource SidebarBorderBrush}" BorderThickness="0,1,0,0">
          <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/><ColumnDefinition Width="32"/></Grid.ColumnDefinitions>
            <Border Width="34" Height="34" CornerRadius="4"
                    Background="{StaticResource PrimaryBrush}"
                    VerticalAlignment="Center" SnapsToDevicePixels="True">
              <TextBlock x:Name="TxtInit" Text="A" FontSize="14" FontWeight="Bold" Foreground="White"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
              <TextBlock x:Name="TxtUserName" Foreground="White" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
              <TextBlock x:Name="TxtUserRole" Foreground="{StaticResource SidebarMutedBrush}"
                         FontSize="10" Margin="0,1,0,0"/>
            </StackPanel>
            <Button Grid.Column="2" Content="🚪" Width="28" Height="28" Background="Transparent"
                    BorderThickness="0" Foreground="{StaticResource SidebarSubtleBrush}"
                    FontSize="13" Cursor="Hand"
                    ToolTip="ອອກຈາກລະບົບ (Ctrl+L)" Click="BtnLogout_Click"/>
          </Grid>
        </Border>

        <!-- Nav -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="2,4,2,4">
            <Button x:Name="NavDash"     Tag="0"  Style="{StaticResource NavButtonActive}" Click="Nav_Click"><TextBlock><Run Text="🏠  "/><Run Text="ໜ້າຫຼັກ"/></TextBlock></Button>
            <Button x:Name="NavClassHub" Tag="1"  Style="{StaticResource NavButton}"       Click="Nav_Click"><TextBlock><Run Text="🏫  "/><Run Text="ໜ້າຫ້ອງຮຽນ"/></TextBlock></Button>

            <TextBlock Text="ຂໍ້ມູນ" Foreground="{StaticResource SidebarMutedBrush}" FontSize="10" FontWeight="SemiBold" Margin="20,12,0,4"/>
            <Button x:Name="NavStud"    Tag="2"  Style="{StaticResource NavButton}"       Click="Nav_Click"><TextBlock><Run Text="👤  "/><Run Text="ຂໍ້ມູນນັກຮຽນ"/></TextBlock></Button>
            <Button x:Name="NavEnroll"  Tag="3"  Style="{StaticResource NavButton}"       Click="Nav_Click"><TextBlock><Run Text="📚  "/><Run Text="ລົງທະບຽນ (ລາຍຄົນ)"/></TextBlock></Button>
            <Button x:Name="NavBatch"   Tag="4"  Style="{StaticResource NavButton}"       Click="Nav_Click"><TextBlock><Run Text="📋  "/><Run Text="ລົງທະບຽນ (Batch)"/></TextBlock></Button>

            <TextBlock Text="ການປະເມີນ" Foreground="{StaticResource SidebarMutedBrush}" FontSize="10" FontWeight="SemiBold" Margin="20,12,0,4"/>
            <Button x:Name="NavScores"  Tag="5"  Style="{StaticResource NavButton}"       Click="Nav_Click"><TextBlock><Run Text="📝  "/><Run Text="ບັນທືກຄະແນນພາກຮຽນ"/></TextBlock></Button>
            <Button x:Name="NavMonthly" Tag="6"  Style="{StaticResource NavButton}"       Click="Nav_Click"><TextBlock><Run Text="📅  "/><Run Text="ບັນທຶກຄະແນນປະຈຳເດືອນ"/></TextBlock></Button>
            <Button x:Name="NavReport"  Tag="7"  Style="{StaticResource NavButton}"       Click="Nav_Click"><TextBlock><Run Text="📄  "/><Run Text="ໃບຄະແນນ / ລາຍງານ"/></TextBlock></Button>
            <Button x:Name="NavHistory" Tag="13" Style="{StaticResource NavButton}"       Click="Nav_Click"><TextBlock><Run Text="📚  "/><Run Text="ປະຫວັດຄະແນນນັກຮຽນ"/></TextBlock></Button>

            <TextBlock Text="ບໍລິຫານ" Foreground="{StaticResource SidebarMutedBrush}" FontSize="10" FontWeight="SemiBold" Margin="20,12,0,4"/>
            <Button x:Name="NavPromo"   Tag="8"  Style="{StaticResource NavButton}"       Click="Nav_Click"><TextBlock><Run Text="🎓  "/><Run Text="ຂຶ້ນຊັ້ນ / ຈົບ"/></TextBlock></Button>
            <Button x:Name="NavSubj"    Tag="9"  Style="{StaticResource NavButton}"       Click="Nav_Click"><TextBlock><Run Text="🗒  "/><Run Text="ວິຊາຮຽນ"/></TextBlock></Button>
            <Button x:Name="NavUsers"    Tag="10" Style="{StaticResource NavButton}"       Click="Nav_Click"><TextBlock><Run Text="👥  "/><Run Text="ຈັດການຜູ້ໃຊ້"/></TextBlock></Button>
            <Button x:Name="NavAcadYear" Tag="11" Style="{StaticResource NavButton}"       Click="Nav_Click"><TextBlock><Run Text="📆  "/><Run Text="ປີການສຶກສາ"/></TextBlock></Button>
            <Button x:Name="NavSett"     Tag="12" Style="{StaticResource NavButton}"       Click="Nav_Click"><TextBlock><Run Text="⚙️  "/><Run Text="ຕັ້ງຄ່າລະບົບ"/></TextBlock></Button>
          </StackPanel>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <!-- ============================================================
         MAIN CONTENT
         ============================================================ -->
    <Grid Grid.Column="1">
      <Grid.RowDefinitions><RowDefinition Height="58"/><RowDefinition Height="*"/></Grid.RowDefinitions>

      <!-- Top bar (flat solid white) -->
      <Border Grid.Row="0" Background="White"
              BorderBrush="{StaticResource BorderBrush_}" BorderThickness="0,0,0,1">
        <Grid Margin="22,0">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock x:Name="TxtTitle" Text="ໜ້າຫຼັກ" Style="{StaticResource PageTitle}"/>
            <TextBlock x:Name="TxtSubtitle" Foreground="{StaticResource TextMutedBrush}" FontSize="12" VerticalAlignment="Bottom" Margin="10,0,0,4"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            <Button x:Name="BtnRefresh" Content="🔄  ໂຫຼດໃໝ່" Style="{StaticResource NeutralButton}"
                    Margin="0,0,12,0" Click="BtnRefresh_Click" ToolTip="ໂຫຼດໃໝ່ (F5)"/>
            <Border CornerRadius="4" Padding="10,5"
                    Background="{StaticResource BgHoverBrush}"
                    BorderBrush="{StaticResource BorderBrush_}" BorderThickness="1"
                    Margin="0,0,8,0" SnapsToDevicePixels="True">
              <TextBlock x:Name="TxtInfo" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
            </Border>
            <Border CornerRadius="4" Padding="10,5"
                    Background="{StaticResource BgHoverBrush}"
                    BorderBrush="{StaticResource BorderBrush_}" BorderThickness="1"
                    SnapsToDevicePixels="True">
              <TextBlock x:Name="TxtClock" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" FontFamily="Consolas"/>
            </Border>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Content area -->
      <Border Grid.Row="1" Background="{StaticResource BgPageBrush}" Padding="18">
        <ContentControl x:Name="Frame"/>
      </Border>
    </Grid>
  </Grid>
</Window>
