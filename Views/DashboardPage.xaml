<UserControl x:Class="StudentSIS.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <UserControl.Resources>
    <!-- Reusable stat-card style (flat) -->
    <Style x:Key="StatCard" TargetType="Border" BasedOn="{StaticResource Card}">
      <Setter Property="Padding" Value="16,14"/>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
        </Trigger>
      </Style.Triggers>
    </Style>
  </UserControl.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="0,0,0,16">

      <!-- ============ Stat cards row ============ -->
      <UniformGrid Rows="1" Columns="5" Margin="0,0,0,16">

        <!-- Total students -->
        <Border Style="{StaticResource StatCard}" Margin="0,0,8,0">
          <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="ນັກຮຽນທັງໝົດ" FontSize="11" FontWeight="Medium" Foreground="{StaticResource TextSecondaryBrush}"/>
              <TextBlock x:Name="TxtTotal"  Text="0" FontSize="32" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <Border Grid.Column="1" Width="40" Height="40" CornerRadius="20" VerticalAlignment="Top">
              <Border.Background><SolidColorBrush Color="#D6E4F7"/></Border.Background>
              <TextBlock Text="👥" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </Grid>
        </Border>

        <!-- Active -->
        <Border Style="{StaticResource StatCard}" Margin="4,0,4,0">
          <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="ກຳລັງຮຽນ" FontSize="11" FontWeight="Medium" Foreground="{StaticResource TextSecondaryBrush}"/>
              <TextBlock x:Name="TxtActive" Text="0" FontSize="32" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <Border Grid.Column="1" Width="40" Height="40" CornerRadius="20" VerticalAlignment="Top">
              <Border.Background><SolidColorBrush Color="#DCFCE7"/></Border.Background>
              <TextBlock Text="✅" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </Grid>
        </Border>

        <!-- Subjects -->
        <Border Style="{StaticResource StatCard}" Margin="4,0,4,0">
          <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="ວິຊາຮຽນ" FontSize="11" FontWeight="Medium" Foreground="{StaticResource TextSecondaryBrush}"/>
              <TextBlock x:Name="TxtSubj"   Text="0" FontSize="32" FontWeight="Bold" Foreground="{StaticResource SecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <Border Grid.Column="1" Width="40" Height="40" CornerRadius="20" VerticalAlignment="Top">
              <Border.Background><SolidColorBrush Color="#EDE3FB"/></Border.Background>
              <TextBlock Text="🗒" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </Grid>
        </Border>

        <!-- Monthly entries recorded — informational (Info brush, not Warning) -->

                <!-- Failing -->
        <Border Style="{StaticResource StatCard}" Margin="8,0,0,0">
          <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="ວິຊາຕົກ" FontSize="11" FontWeight="Medium" Foreground="{StaticResource TextSecondaryBrush}"/>
              <TextBlock x:Name="TxtFail"   Text="0" FontSize="32" FontWeight="Bold" Foreground="{StaticResource DangerBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <Border Grid.Column="1" Width="40" Height="40" CornerRadius="20" VerticalAlignment="Top">
              <Border.Background><SolidColorBrush Color="#FEE2E2"/></Border.Background>
              <TextBlock Text="⚠" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </Grid>
        </Border>
      </UniformGrid>

      <!-- ============ Chart + side panel ============ -->
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
          <StackPanel>
            <Grid Margin="0,0,0,12">
              <TextBlock Text="📊  ຈຳນວນນັກຮຽນແຍກຕາມຊັ້ນ" Style="{StaticResource SectionTitle}" Margin="0"/>
              <TextBlock Text="ປັດຈຸບັນ" HorizontalAlignment="Right" VerticalAlignment="Center"
                         FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
            </Grid>
            <Canvas x:Name="ChartCanvas" Height="260" SizeChanged="ChartCanvas_SizeChanged"/>
          </StackPanel>
        </Border>

        <StackPanel Grid.Column="1">
          <Border Style="{StaticResource Card}" Margin="0,0,0,12">
            <StackPanel>
              <TextBlock Text="🏫  ສະຫຼຸບແຍກຊັ້ນ" Style="{StaticResource SectionTitle}"/>
              <DataGrid x:Name="GradeTable" Height="160" AutoGenerateColumns="False" HeadersVisibility="Column">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="ຊັ້ນ"      Binding="{Binding GradeLevel}" Width="70"/>
                  <DataGridTextColumn Header="ຈຳນວນ"    Binding="{Binding Count}"      Width="*"/>
                  <DataGridTextColumn Header="ກຳລັງຮຽນ" Binding="{Binding Active}"     Width="*"/>
                </DataGrid.Columns>
              </DataGrid>
            </StackPanel>
          </Border>
          <Border Style="{StaticResource Card}">
            <StackPanel>
              <TextBlock Text="📢  ແຈ້ງການ" Style="{StaticResource SectionTitle}"/>
              <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="AnnList">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,0,8" Padding="12,9" CornerRadius="8" Background="#F8FAFC"
                              BorderBrush="{StaticResource BorderBrush_}" BorderThickness="1">
                        <StackPanel>
                          <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                          <TextBlock Text="{Binding CreatedAt}" FontSize="11"
                                     Foreground="{StaticResource TextMutedBrush}" Margin="0,3,0,0"/>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
