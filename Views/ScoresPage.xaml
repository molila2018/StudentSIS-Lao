<UserControl x:Class="StudentSIS.Views.ScoresPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:StudentSIS.Helpers">
  <UserControl.Resources>
    <h:LevelToFgConverter x:Key="LvlFg"/>
    <h:LevelToBgConverter x:Key="LvlBg"/>
  </UserControl.Resources>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- filter / action bar -->
      <RowDefinition Height="Auto"/>  <!-- formula hint -->
      <RowDefinition Height="*"/>     <!-- score grid -->
      <RowDefinition Height="Auto"/>  <!-- footer hint -->
    </Grid.RowDefinitions>

    <!-- Filter / action bar. Class-roster × one-subject model, same shape as
         MonthlyScoresPage. Pick ປີ · ຊັ້ນ · ຫ້ອງ · ສະຖານະ · ວິຊາ · ພາກ → grid
         loads the whole class for that subject → enter ສອບເສງ down the column
         → Ctrl+S saves all. Switch ວິຊາ to start the next subject. -->
    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,10" Padding="14,10">
      <WrapPanel>
        <TextBlock Text="ປີ:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource TextSecondaryBrush}"/>
        <ComboBox x:Name="CmbYear" Width="100" Margin="0,0,8,0" SelectionChanged="Filter_Changed"/>
        <TextBlock Text="ຊັ້ນ:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource TextSecondaryBrush}"/>
        <ComboBox x:Name="CmbGrade" Width="80" Margin="0,0,8,0" SelectionChanged="Grade_Changed"/>
        <TextBlock Text="ຫ້ອງ:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource TextSecondaryBrush}"/>
        <ComboBox x:Name="CmbRoom" Width="70" Margin="0,0,8,0" SelectionChanged="Filter_Changed"/>
        <TextBlock Text="ສະຖານະ:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource TextSecondaryBrush}"/>
        <ComboBox x:Name="CmbStatus" Width="100" Margin="0,0,12,0" SelectionChanged="Filter_Changed"/>
        <TextBlock Text="ວິຊາ:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource TextSecondaryBrush}"/>
        <ComboBox x:Name="CmbSubject" Width="240" Margin="0,0,8,0" DisplayMemberPath="Display"
                  SelectionChanged="Subject_Changed"/>
        <TextBlock Text="ພາກ:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource TextSecondaryBrush}"/>
        <ComboBox x:Name="CmbSem" Width="100" Margin="0,0,12,0" SelectionChanged="Sem_Changed"/>
        <Button x:Name="BtnSave" Content="💾  ບັນທຶກ (Ctrl+S)" Style="{StaticResource SuccessButton}" Click="BtnSave_Click" Margin="0,0,8,0"/>
        <!-- Import / Download — Subject pick comes from the main CmbSubject above
             so there's no separate subject combo for imports anymore. -->
        <Button x:Name="BtnDownload" Content="📥  ດາວໂຫຼດແບບຟອມ" Style="{StaticResource SecondaryButton}" Click="BtnDownload_Click" Margin="0,0,4,0"/>
        <Button x:Name="BtnImport"   Content="📤  ນຳເຂົ້າ Excel"  Style="{StaticResource PrimaryButton}"   Click="BtnImport_Click"/>
        <TextBlock x:Name="TxtSaveInfo" VerticalAlignment="Center" Margin="14,0,0,0" FontSize="12"
                   Foreground="{StaticResource TextSecondaryBrush}"/>
      </WrapPanel>
    </Border>

    <!-- Formula hint -->
    <Border Grid.Row="1" Background="#EFF6FF" BorderBrush="#D6E4F7" BorderThickness="1"
            CornerRadius="4" Padding="12,7" Margin="0,0,0,10">
      <TextBlock Foreground="{StaticResource PrimaryBrush}" FontSize="12" TextWrapping="Wrap">
        <Run FontWeight="SemiBold">ສູດຄຳນວນ:</Run>
        <Run x:Name="TxtFormula" Text=""/>
      </TextBlock>
    </Border>

    <!-- Score grid: rows = roster students, columns depend on subject:
           Academic   → # · code · name · Mid (RO) · Final (edit) · Total · Level
           CHA1/LAB1  → # · code · name · ຄະແນນ /10 (edit)
         CellEditEnding validates integers 0-10. Enter on the Final cell commits
         + moves the selection DOWN to the next row (handled in code-behind). -->
    <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
      <DataGrid x:Name="ScoreGrid" AutoGenerateColumns="False"
                IsReadOnly="False" CanUserAddRows="False"
                CellEditEnding="ScoreGrid_CellEditEnding"
                PreparingCellForEdit="ScoreGrid_PreparingCellForEdit">
        <DataGrid.Columns>
          <DataGridTextColumn Header="#"           Binding="{Binding RowNo}"       Width="50"  IsReadOnly="True"/>
          <DataGridTextColumn Header="ລະຫັດ"      Binding="{Binding StudentCode}" Width="110" IsReadOnly="True"/>
          <DataGridTextColumn Header="ຊື່ນັກຮຽນ"  Binding="{Binding FullName}"    Width="*"   IsReadOnly="True"/>
          <DataGridTextColumn x:Name="ColMid"     Header="ສະເລ່ຍປະຈຳເດືອນ (/10)"
                              Binding="{Binding MidScore,StringFormat=F2}"  Width="155" IsReadOnly="True"
                              ElementStyle="{StaticResource ScoreDisplayText}"/>
          <DataGridTextColumn x:Name="ColFinal"   Header="ສອບເສງພາກຮຽນ (/10)"
                              Binding="{Binding FinalScore,StringFormat=F0,UpdateSourceTrigger=PropertyChanged}"
                              Width="150"
                              CellStyle="{StaticResource ScoreEditableCell}"
                              ElementStyle="{StaticResource ScoreDisplayText}"
                              EditingElementStyle="{StaticResource ScoreEditBox}"/>
          <DataGridTextColumn x:Name="ColTotal"   Header="ສະເລ່ຍ (/10)"
                              Binding="{Binding TotalScore,StringFormat=F2}" Width="110" IsReadOnly="True"
                              ElementStyle="{StaticResource ScoreDisplayText}"/>
          <DataGridTemplateColumn x:Name="ColLevel" Header="ລະດັບ" Width="90" IsReadOnly="True">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <Border CornerRadius="3" Padding="8,2" HorizontalAlignment="Left"
                        Background="{Binding Level,Converter={StaticResource LvlBg}}">
                  <TextBlock Text="{Binding Level}" FontSize="12" FontWeight="SemiBold"
                             Foreground="{Binding Level,Converter={StaticResource LvlFg}}"/>
                </Border>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <!-- Eval column only visible when subject = CHA1/LAB1. Replaces
               Mid + Final + Total + Level. Single editable /10 cell. -->
          <DataGridTextColumn x:Name="ColEval"    Header="ຄະແນນ (/10)" Width="150"
                              Visibility="Collapsed"
                              Binding="{Binding EvalScore,StringFormat=F0,TargetNullValue='',UpdateSourceTrigger=PropertyChanged}"
                              CellStyle="{StaticResource ScoreEditableCell}"
                              ElementStyle="{StaticResource ScoreDisplayText}"
                              EditingElementStyle="{StaticResource ScoreEditBox}"/>
        </DataGrid.Columns>
        <DataGrid.RowStyle>
          <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Style.Triggers>
              <DataTrigger Binding="{Binding Level}" Value="ບໍ່ຜ່ານ"><Setter Property="Background" Value="#FEF2F2"/></DataTrigger>
              <DataTrigger Binding="{Binding Level}" Value="ດີຫຼາຍ"><Setter Property="Background" Value="#F0FDF4"/></DataTrigger>
            </Style.Triggers>
          </Style>
        </DataGrid.RowStyle>
      </DataGrid>
    </Border>

    <!-- Footer hint -->
    <Border Grid.Row="3" Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1"
            CornerRadius="4" Padding="12,6" Margin="0,8,0,0">
      <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" TextWrapping="Wrap">
        💡 ຕົວກອງທັງໝົດໂຫຼດຂໍ້ມູນອັດຕະໂນມັດ  ·  ກົດ Enter ໃນຊ່ອງສອບເສງ → ໄປແຖວຖັດໄປ  ·  Ctrl+S ບັນທຶກ  ·  F5 ໂຫຼດໃໝ່
      </TextBlock>
    </Border>
  </Grid>
</UserControl>
