<Window x:Class="StudentSIS.Views.StudentFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ຂໍ້ມູນນັກຮຽນ" Width="780" Height="720"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"
        FontFamily="{DynamicResource AppFont}"
        Background="{StaticResource BgPageBrush}">
  <Grid>
    <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="56"/></Grid.RowDefinitions>
    <TabControl Grid.Row="0" Margin="14,14,14,0" BorderThickness="0" Background="Transparent">

      <!-- ============ TAB 1 — PERSONAL ============ -->
      <TabItem Header="👤  ຂໍ້ມູນສ່ວນຕົວ">
        <ScrollViewer Padding="18,14" VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <Border Style="{StaticResource Card}">
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,12">
                  <TextBlock Text="ລະຫັດນັກຮຽນ *" Style="{StaticResource FieldLabel}"/>
                  <TextBox x:Name="TxtCode"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,12">
                  <TextBlock Text="ຊື່ " Style="{StaticResource FieldLabel}"/>
                  <TextBox x:Name="TxtFirst"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,12">
                  <TextBlock Text="ນາມສະກຸນ " Style="{StaticResource FieldLabel}"/>
                  <TextBox x:Name="TxtLast"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,0">
                  <TextBlock Text="ເພດ" Style="{StaticResource FieldLabel}"/>
                  <ComboBox x:Name="CmbGender">
                    <ComboBoxItem Content="ຊາຍ" IsSelected="True"/>
                    <ComboBoxItem Content="ຍິງ"/>
                  </ComboBox>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,0">
                  <TextBlock Text="ວັນເດືອນປີເກີດ" Style="{StaticResource FieldLabel}"/>
                  <TextBox x:Name="TxtBirth"/>
                </StackPanel>
              </Grid>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- ============ TAB 2 — ADDRESS ============ -->
      <TabItem Header="🏠  ທີ່ຢູ່">
        <ScrollViewer Padding="18,14" VerticalScrollBarVisibility="Auto">
          <StackPanel>

            <!-- Birth place -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
              <StackPanel>
                <TextBlock Text="📍  ສະຖານທີ່ເກີດ" Style="{StaticResource SectionTitle}"/>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="0,0,6,0">
                    <TextBlock Text="ບ້ານເກີດ " Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtBirthVill"/>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Margin="6,0,6,0">
                    <TextBlock Text="ເມືອງເກີດ " Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtBirthCity"/>
                  </StackPanel>
                  <StackPanel Grid.Column="2" Margin="6,0,0,0">
                    <TextBlock Text="ແຂວງເກີດ " Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtBirthProv"/>
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>

            <!-- Current address -->
            <Border Style="{StaticResource Card}">
              <StackPanel>
                <TextBlock Text="🏘  ທີ່ຢູ່ປັດຈຸບັນ" Style="{StaticResource SectionTitle}"/>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="0,0,6,0">
                    <TextBlock Text="ບ້ານ " Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtVillage"/>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Margin="6,0,6,0">
                    <TextBlock Text="ເມືອງ " Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtDistrict"/>
                  </StackPanel>
                  <StackPanel Grid.Column="2" Margin="6,0,0,0">
                    <TextBlock Text="ແຂວງ" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtProvince"/>
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- ============ TAB 3 — PARENTS ============ -->
      <TabItem Header="👨‍👩‍👧  ຂໍ້ມູນພໍ່ແມ່">
        <ScrollViewer Padding="18,14" VerticalScrollBarVisibility="Auto">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Father (st_fa_*) -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,6,0">
              <StackPanel>
                <TextBlock Text="👨  ຂໍ້ມູນພໍ່" Style="{StaticResource SectionTitle}"/>

                <TextBlock Text="ຊື່ ແລະ ນາມສະກຸນ " Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtFaName" Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,10">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="0,0,4,0">
                    <TextBlock Text="ອາຍຸ " Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtFaAge"/>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Margin="4,0,0,0">
                    <TextBlock Text="ໂທລະສັບ " Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtFaTel"/>
                  </StackPanel>
                </Grid>

                <TextBlock Text="ອາຊີບ " Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtFaJob" Margin="0,0,0,10"/>

                <TextBlock Text="ບ້ານ " Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtFaVill" Margin="0,0,0,10"/>
                <TextBlock Text="ເມືອງ " Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtFaCity" Margin="0,0,0,10"/>
                <TextBlock Text="ແຂວງ" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtFaProv"/>
              </StackPanel>
            </Border>

            <!-- Mother (st_ma_*) -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="6,0,0,0">
              <StackPanel>
                <TextBlock Text="👩  ຂໍ້ມູນແມ່" Style="{StaticResource SectionTitle}"/>

                <TextBlock Text="ຊື່ ແລະ ນາມສະກຸນ " Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtMaName" Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,10">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="0,0,4,0">
                    <TextBlock Text="ອາຍຸ " Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtMaAge"/>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Margin="4,0,0,0">
                    <TextBlock Text="ໂທລະສັບ " Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtMaTel"/>
                  </StackPanel>
                </Grid>

                <TextBlock Text="ອາຊີບ " Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtMaJob" Margin="0,0,0,10"/>

                <TextBlock Text="ບ້ານ " Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtMaVill" Margin="0,0,0,10"/>
                <TextBlock Text="ເມືອງ " Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtMaCity" Margin="0,0,0,10"/>
                <TextBlock Text="ແຂວງ " Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtMaProv"/>
              </StackPanel>
            </Border>
          </Grid>
        </ScrollViewer>
      </TabItem>

      <!-- ============ TAB 4 — ACADEMIC ============ -->
      <TabItem Header="🎓  ຂໍ້ມູນການຮຽນ">
        <ScrollViewer Padding="18,14" VerticalScrollBarVisibility="Auto">
          <Border Style="{StaticResource Card}">
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,12">
                <TextBlock Text="ຊັ້ນຮຽນ *" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="CmbGrade">
                  <ComboBoxItem Content="ມ.1"/>
                  <ComboBoxItem Content="ມ.2"/>
                  <ComboBoxItem Content="ມ.3"/>
                  <ComboBoxItem Content="ມ.4" IsSelected="True"/>
                </ComboBox>
              </StackPanel>
              <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,12">
                <TextBlock Text="ຫ້ອງ" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="CmbRoom">
                  <ComboBoxItem Content="1" IsSelected="True"/>
                  <ComboBoxItem Content="2"/>
                  <ComboBoxItem Content="3"/>
                  <ComboBoxItem Content="4"/>
                  <ComboBoxItem Content="5"/>
                  <ComboBoxItem Content="6"/>
                </ComboBox>
              </StackPanel>
              <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,12">
                <TextBlock Text="ປີການສຶກສາ *" Style="{StaticResource FieldLabel}"/>
                <!-- Items populated at runtime from DB.AcademicYears() -->
                <ComboBox x:Name="CmbYear"/>
              </StackPanel>
              <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,12">
                <TextBlock Text="ສະຖານະ" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="CmbStatus">
                  <ComboBoxItem Content="ກຳລັງຮຽນ" IsSelected="True"/>
                  <ComboBoxItem Content="ຈົບ"/>
                  <ComboBoxItem Content="ອອກ"/>
                </ComboBox>
              </StackPanel>
              <StackPanel Grid.Row="2" Grid.ColumnSpan="2">
                <TextBlock Text="ໝາຍເຫດ" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtNote" Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>
              </StackPanel>
            </Grid>
          </Border>
        </ScrollViewer>
      </TabItem>
    </TabControl>

    <!-- Footer -->
    <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderBrush_}"
            BorderThickness="0,1,0,0" Padding="14,10">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="💾  ບັນທຶກ" Style="{StaticResource SuccessButton}"
                Width="120" Margin="0,0,8,0" Click="BtnSave_Click"/>
        <Button Content="ຍົກເລີກ" Style="{StaticResource NeutralButton}"
                Width="90" IsCancel="True"/>
      </StackPanel>
    </Border>
  </Grid>
</Window>
