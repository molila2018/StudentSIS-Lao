<UserControl x:Class="StudentSIS.Views.ReportPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,10" Padding="14,10">
      <StackPanel>
        <WrapPanel>
          <TextBlock Text="ປະເພດ:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource TextSecondaryBrush}"/>
          <!-- Score-related report types (Monthly / Sem 1 / Sem 2 / Annual /
               Individual) live on the ປະຫວັດຄະແນນນັກຮຽນ page now — this page
               keeps only NON-SCORE administrative reports. -->
          <ComboBox x:Name="CmbType" Width="290" Margin="0,0,12,0" SelectionChanged="CmbType_Changed">
            <ComboBoxItem Content="📑  ໃບສັນຍາເຂົ້າຮຽນ (Word / PDF)"/>
            <ComboBoxItem Content="📋  ລາຍງານປະຫວັດນັກຮຽນ (Profile, Word/PDF)"/>
          </ComboBox>
          <TextBlock Text="ປີ:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource TextSecondaryBrush}"/>
          <ComboBox x:Name="CmbYear" Width="100" Margin="0,0,10,0"/>
          <TextBlock Text="ພາກ:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource TextSecondaryBrush}"/>
          <ComboBox x:Name="CmbSem" Width="80" Margin="0,0,14,0"/>
          <!-- Both remaining reports are Word-based (docx → PDF). The old
               "ສ້າງ Excel" button was a leftover from the score-report era
               (moved to ScoreHistoryPage) and no longer applies here. -->
          <Button Content="📄  ສ້າງ PDF"   Style="{StaticResource DangerButton}"  Click="BtnPdf_Click"/>
        </WrapPanel>
        <WrapPanel x:Name="StudentPickerRow" Margin="0,8,0,0">
          <TextBlock Text="ສະຖານະ:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource TextSecondaryBrush}"/>
          <ComboBox x:Name="CmbStudentStatus" Width="110" Margin="0,0,12,0" SelectionChanged="Class_Changed"/>
          <TextBlock Text="ນັກຮຽນ:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource TextSecondaryBrush}"/>
          <ComboBox x:Name="CmbStudent" Width="380" Margin="0,0,8,0"/>
          <TextBlock x:Name="TxtStudentCount" VerticalAlignment="Center" Margin="0,0,12,0"
                     FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
        </WrapPanel>
        <WrapPanel x:Name="ClassPickerRow" Margin="0,8,0,0" Visibility="Collapsed">
          <TextBlock Text="ຊັ້ນ:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource TextSecondaryBrush}"/>
          <ComboBox x:Name="CmbGrade" Width="90" Margin="0,0,10,0"/>
          <TextBlock Text="ຫ້ອງ:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource TextSecondaryBrush}"/>
          <ComboBox x:Name="CmbRoom" Width="80" Margin="0,0,10,0"/>
        </WrapPanel>
      </StackPanel>
    </Border>
    <TabControl Grid.Row="1">
      <TabItem Header="📄  ຂໍ້ຄວາມ">
        <Border Style="{StaticResource Card}" Padding="0">
          <TextBox x:Name="TxtOut" IsReadOnly="True" FontFamily="Courier New" FontSize="12"
                   VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                   Background="White" BorderThickness="0" TextWrapping="NoWrap" Padding="16"/>
        </Border>
      </TabItem>
      <TabItem Header="📊  ຕາຕະລາງ">
        <Border Style="{StaticResource Card}" Padding="0">
          <DataGrid x:Name="TblOut" AutoGenerateColumns="True"/>
        </Border>
      </TabItem>
    </TabControl>
  </Grid>
</UserControl>
