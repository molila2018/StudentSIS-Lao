<UserControl x:Class="StudentSIS.Views.StudentsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:StudentSIS.Helpers">
  <UserControl.Resources>
    <h:StatusToFgConverter x:Key="StFg"/>
    <h:StatusToBgConverter   x:Key="StBg"/>
  </UserControl.Resources>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,10" Padding="14,10">
      <WrapPanel>
        <Button Content="➕  ເພີ່ມນັກຮຽນ" Style="{StaticResource SuccessButton}" Margin="0,0,6,0" Click="BtnAdd_Click"/>
        <Button Content="✏️  ແກ້ໄຂ"       Style="{StaticResource PrimaryButton}" Margin="0,0,6,0" Click="BtnEdit_Click"/>
        <Button Content="🗑  ລຶບ"          Style="{StaticResource DangerButton}"  Margin="0,0,14,0" Click="BtnDelete_Click"/>
        <TextBox x:Name="TxtSearch" Width="180" Margin="0,0,8,0" TextChanged="Filter_Changed"/>
        <TextBlock Text="ຊັ້ນ:" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource TextSecondaryBrush}"/>
        <ComboBox x:Name="CmbGrade"  Width="80"  Margin="0,0,6,0" SelectionChanged="Filter_Changed"/>
        <TextBlock Text="ຫ້ອງ:"  VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource TextSecondaryBrush}"/>
        <ComboBox x:Name="CmbRoom"   Width="70"  Margin="0,0,6,0" SelectionChanged="Filter_Changed"/>
        <TextBlock Text="ປີ:" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource TextSecondaryBrush}"/>
        <ComboBox x:Name="CmbYear"   Width="100" Margin="0,0,6,0" SelectionChanged="Filter_Changed"/>
        <TextBlock Text="ສະຖານະ:" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource TextSecondaryBrush}"/>
        <ComboBox x:Name="CmbStatus" Width="110" Margin="0,0,10,0" SelectionChanged="Filter_Changed"/>
        <TextBlock x:Name="LblCount" VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
      </WrapPanel>
    </Border>
    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
      <DataGrid x:Name="StudentGrid" AutoGenerateColumns="False" MouseDoubleClick="Grid_DoubleClick">
        <DataGrid.Columns>
          <DataGridTextColumn Header="ລະຫັດ"      Binding="{Binding StudentCode}" Width="100"/>
          <DataGridTextColumn Header="ຊື່ນັກຮຽນ"   Binding="{Binding FullName}"    Width="*"/>
          <DataGridTextColumn Header="ເພດ"         Binding="{Binding Gender}"      Width="60"/>
          <DataGridTextColumn Header="ຊັ້ນ"         Binding="{Binding GradeLevel}"  Width="70"/>
          <DataGridTextColumn Header="ຫ້ອງ"        Binding="{Binding ClassRoom}"   Width="60"/>
          <DataGridTextColumn Header="ປີການສຶກສາ"  Binding="{Binding AcademicYear}" Width="100"/>
          <DataGridTextColumn Header="ຜູ້ປົກຄອງ"   Binding="{Binding ParentName}"  Width="140"/>
          <DataGridTemplateColumn Header="ສະຖານະ" Width="100">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <Border CornerRadius="12" Padding="8,2" HorizontalAlignment="Left"
                        Background="{Binding Status, Converter={StaticResource StBg}}">
                  <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold"
                             Foreground="{Binding Status, Converter={StaticResource StFg}}"/>
                </Border>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Border>
    <Border Grid.Row="2" Style="{StaticResource Card}" Padding="12,6" Margin="0,8,0,0">
      <TextBlock x:Name="LblStatus" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
    </Border>
  </Grid>
</UserControl>
